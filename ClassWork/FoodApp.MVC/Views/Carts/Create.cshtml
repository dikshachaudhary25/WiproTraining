@model FoodApp.MVC.Models.Cart

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Cart</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- CATEGORY -->
            <div class="form-group">
                <label>Category</label>
                <select id="categoryID" class="form-control"
                        asp-items="ViewBag.CategoryId">
                    <option value="">Select Category</option>
                </select>
            </div>

            <!-- FOOD -->
            <div class="form-group">
                <label asp-for="FoodId" class="control-label"></label>
                <select asp-for="FoodId" id="foodID" class="form-control"></select>
                <span asp-validation-for="FoodId" class="text-danger"></span>
            </div>

            <!-- QTY -->
            <div class="form-group">
                <label asp-for="Qty" class="control-label"></label>
                <input asp-for="Qty" class="form-control" id="qtyBox" />
                <span asp-validation-for="Qty" class="text-danger"></span>
            </div>

            <!-- PRICE -->
            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" class="form-control" id="priceBox" readonly />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <!-- TOTAL -->
            <div class="form-group">
                <label asp-for="TotalAmount" class="control-label"></label>
                <input asp-for="TotalAmount" class="form-control" id="totalBox" readonly />
                <span asp-validation-for="TotalAmount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {

            // 🔹 Load foods when category changes
            var foodUrl = '@Url.Action("FetchFoods","Carts")';

            $("#categoryID").change(function () {

                var id = $(this).val();

                $.getJSON(foodUrl, { cid: id }, function (response) {

                    var foodDropdown = $("#foodID");

                    foodDropdown.empty();
                    foodDropdown.append($('<option>').text("Select Food").val(""));

                    $.each(response, function (index, item) {
                        foodDropdown.append(
                            $('<option>').text(item.text).val(item.id)
                        );
                    });

                });

            });


            // 🔹 Load price when food changes
            var priceUrl = '@Url.Action("GetFoodPrice","Carts")';

            $("#foodID").change(function () {

                var foodId = $(this).val();

                $.getJSON(priceUrl, { foodId: foodId }, function (data) {

                    $("#priceBox").val(data);

                    var qty = $("#qtyBox").val();

                    if (qty) {
                        $("#totalBox").val(qty * data);
                    }

                });

            });


            // 🔹 Auto total when qty changes
            $("#qtyBox").keyup(function () {

                var qty = $(this).val();
                var price = $("#priceBox").val();

                if (qty && price) {
                    $("#totalBox").val(qty * price);
                }

            });

        });
    </script>
}