@model FoodApp.MVC.Models.Party
@{
    ViewData["Title"] = "Sign Up";
}

<h1>Party Sign Up</h1>

<hr />
<div class="row">
    <div class="col-md-5">
        <div class="form-group mb-3">
            <label class="control-label fw-bold">Select Party</label>
            <select id="partyDropdown" class="form-control" asp-items="ViewBag.PartyId">
                <option value="">-- Select a Party --</option>
            </select>
        </div>

        <div id="signupSection" style="display:none;" class="mt-4 p-3 border rounded border-success bg-light">
            <h4 class="text-success mb-3">Proceed to sign up</h4>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">Sign Up</a>
        </div>
        
        <div id="externalMessage" style="display:none;" class="mt-4 p-3 border rounded border-danger bg-light">
            <p class="text-danger mb-0 fw-bold">Sign up is not allowed for external parties.</p>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#partyDropdown').change(function () {
                var selectedPartyId = $(this).val();
                
                // Hide sections initially when changing selection
                $('#signupSection').hide();
                $('#externalMessage').hide();

                if (selectedPartyId) {
                    // Make AJAX call to AllowSignUp
                    $.ajax({
                        url: '/Parties/AllowSignUp',
                        type: 'GET',
                        data: { partyId: selectedPartyId },
                        success: function (response) {
                            // Check the returned JSON data
                            if (response.status === "internal") {
                                // For internal parties, show the signup div
                                $('#signupSection').show();
                            } else if (response.status === "external") {
                                // For external, do not allow
                                $('#externalMessage').show();
                            }
                        },
                        error: function (error) {
                            console.error("Error checking party status:", error);
                        }
                    });
                }
            });
        });
    </script>
}
